---
#inhibit_rules:
#- source_match:
#    severity: critical
#  target_match:
#    severity: warning

inhibit_rules:
- source_match:
    severity: critical
  target_match:
    severity: error
{% if (alert_email is defined) and (alert_slack is defined ) and (alert_teams is defined) and (alert_telegram is defined) %}
route:
  receiver: 'default'
{% if (alert_teams == "yes")%}
  group_by: ['alertname', 'node_name']
{% else %}
  group_by: ['alertname']
{% endif %}
  resolve_timeout: 5s
  scrape_interval: 5s
  evaluation_interval: 30s
  group_wait: 30s
  group_interval: 30s
  repeat_interval: 5m
receivers:
- name: 'default'
{% if (alert_teams == "yes") and (alert_telegram == "yes") %}
  webhook_configs:
  - url: http://localhost:2000/alertmanager
    send_resolved: true
  - url: http://localhost:9999/alert
    send_resolved: true
{% else %}
{% endif %}
{% if (alert_teams == "yes") and (alert_telegram == "no") %}
  webhook_configs:
  - url: http://localhost:2000/alertmanager
    send_resolved: true
{% else %}
{% endif %}
{% if (alert_telegram == "yes") and (alert_teams == "no") %}
  webhook_configs:
  - url: http://localhost:9999/alert
    send_resolved: true
{% else %}
{% endif %}
{% if alert_email == "yes" %}
  email_configs:
  - to: {{ address_email }}
    from: mailer.xplat@fpt.com.vn
    smarthost: mail.fpt.com.vn:587
    auth_username: mailer.xplat@fpt.com.vn
    auth_identity: mailer.xplat@fpt.com.vn
    auth_password: Fci@FCI123456
    require_tls: true
    send_resolved: true
{% else %}
{% endif %}
{% if alert_slack == "yes" %}
  slack_configs:
  - channel: '{{ channel_slack }}'
    api_url: '{{ address_slack }}'
    send_resolved: true
    http_config: {}
{% raw %}
    title: |-
      [{{ .Status | toUpper }}{{ if eq .Status "firing" }}:{{ .Alerts.Firing | len }}{{ end }}] {{ .CommonLabels.alertname }}
    text: >-
      {{ with index .Alerts 0 -}}
        :chart_with_upwards_trend: *<{{ .GeneratorURL }}|Graph>*      :spiral_note_pad: *<{{ .Annotations.runbook }}|Runbook>*
      {{ end }}
      *Alert details*:

      {{ range .Alerts -}}
      *Rule:* {{ .Annotations.description }}

      *Details:*
        {{ range .Labels.SortedPairs }} • *{{ .Name }}:* `{{ .Value }}`
        {{ end }}
      {{ end }}
    icon_url: "https://i.imgur.com/qvuuXc8.png"
{% endraw %}
{% else %}
{% endif %}
{% else %}
{% endif %}
